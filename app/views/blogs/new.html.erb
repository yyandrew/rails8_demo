<% content_for :title, "New blog" %>

<section class="content-narrow">
  <div class="panel">
    <p class="chip">Create</p>
    <h2 class="subheading">New blog</h2>
    <p class="title-note">Creator: <strong><%= current_user.username %></strong></p>

    <div class="stack-md">
      <%= render "form", blog: @blog %>
      <div class="button-row">
        <%= link_to "Back to blogs", blogs_path, class: "button button-secondary" %>
      </div>
    </div>
  </div>
</section>

<p style="color: green"><%= notice %></p>

<% content_for :title, "My Blogs" %>

<nav>
  <%= link_to "Blogs", blogs_path %> |
  <%= link_to "Users", users_path %>
</nav>

<h1>Blogs</h1>

<div id="blogs">
  <% @blogs.each do |blog| %>
    <%= render blog %>
    <p>
      <%= link_to "Show this blog", blog %>
    </p>
  <% end %>
</div>

<%= link_to "New blog", new_blog_path %>

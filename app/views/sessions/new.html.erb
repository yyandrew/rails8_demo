<% content_for :title, "Login" %>

<section class="content-narrow">
  <div class="panel">
    <p class="chip">Welcome back</p>
    <h2 class="subheading">Login</h2>
    <p class="title-note">Use your username and password to manage your own blogs.</p>

    <%= form_with url: login_path, class: "form-stack" do |form| %>
      <div class="form-field">
        <%= form.label :username %>
        <%= form.text_field :username, class: "field", placeholder: "Your username" %>
      </div>

      <div class="form-field">
        <%= form.label :password %>
        <%= form.password_field :password, class: "field", placeholder: "Your password" %>
      </div>

      <div class="button-row">
        <%= form.submit "Login", class: "button button-primary" %>
        <%= link_to "Create an account", signup_path, class: "button button-secondary" %>
      </div>
    <% end %>
  </div>
</section>

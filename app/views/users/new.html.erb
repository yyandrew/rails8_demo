<% content_for :title, "New user" %>

<section class="content-narrow">
  <div class="panel">
    <p class="chip">Register</p>
    <h2 class="subheading">Create your account</h2>
    <p class="title-note">Once registered, you can sign in and create blogs under your own username.</p>

    <div class="stack-md">
      <%= render "form", user: @user %>
      <div class="button-row">
        <%= link_to "Back to users", users_path, class: "button button-secondary" %>
      </div>
    </div>
  </div>
</section>

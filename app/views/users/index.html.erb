<p style="color: green"><%= notice %></p>

<% content_for :title, "Users" %>

<nav>
  <%= link_to "Blogs", blogs_path %> |
  <%= link_to "Users", users_path %>
</nav>

<h1>Users</h1>

<div id="users">
  <% @users.each do |user| %>
    <%= render user %>
    <p>
      <%= link_to "Show this user", user %>
    </p>
  <% end %>
</div>

<%= link_to "New user", new_user_path %>
